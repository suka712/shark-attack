{
  "manifest_version": 3,
  "name": "Typewright - write content to a Googlesheet",
  "version": "1.0.0",
  "description": "Write content to a Googlesheet using OAuth",
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["identity"],
  "oauth2": {
    "client_id": "667830119015-0578m330dc70aj2h1d60n06hvmqu4o0e.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/spreadsheets"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
